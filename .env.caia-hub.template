# =============================================================================
# CAIA-HUB Environment Variables Template
# =============================================================================
# Copia este archivo a ~/.env.caia-hub y reemplaza todos los [PLACEHOLDER]
# con tus credenciales reales.
#
# Instrucciones de seguridad:
# - Nunca commits este archivo a Git
# - Nunca lo compartas públicamente
# - Usa permisos 600: chmod 600 ~/.env.caia-hub
# =============================================================================

# SUPABASE CAIA-HUB PROJECT
SUPABASE_CAIA_HUB_URL=https://[YOUR_PROJECT_ID].supabase.co
SUPABASE_CAIA_HUB_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# NASA EARTHDATA (para descargar datos NOAA, MODIS, Landsat, etc.)
NASA_EARTHDATA_USERNAME=[YOUR_EARTHDATA_USERNAME]
NASA_EARTHDATA_TOKEN=[YOUR_EARTHDATA_TOKEN]

# COPERNICUS CDS (Climate Data Store - ERA5, CAMS aerosoles)
COPERNICUS_CDS_API_KEY=[YOUR_CDS_API_KEY]
COPERNICUS_CDS_URL=https://cds.climate.copernicus.eu/api/v2

# COPERNICUS CMEMS (Marine data - corrientes, temperatura)
COPERNICUS_CMEMS_USERNAME=[YOUR_CMEMS_USERNAME]
COPERNICUS_CMEMS_PASSWORD=[YOUR_CMEMS_PASSWORD]

# USGS M2M (Landsat, Sentinel access)
USGS_M2M_API_KEY=[YOUR_USGS_M2M_API_KEY]

# LAADS DAAC (MODIS data)
LAADS_DAAC_TOKEN=[YOUR_LAADS_TOKEN]

# ESA CCI (Soil moisture, vegetation indices)
ESA_CCI_FTP_USER=[YOUR_ESA_CCI_FTP_USER]
ESA_CCI_FTP_PASS=[YOUR_ESA_CCI_FTP_PASS]

# =============================================================================
# CROSS-PROJECT SUPABASE BRIDGES (opcional para primeras ejecuciones)
# =============================================================================

# move-idworld
SUPABASE_MOVE_IDWORLD_URL=https://[PROJECT_ID].supabase.co
SUPABASE_MOVE_IDWORLD_SERVICE_ROLE_KEY=[KEY]

# iAgri-Master
SUPABASE_IAGRI_MASTER_URL=https://[PROJECT_ID].supabase.co
SUPABASE_IAGRI_MASTER_SERVICE_ROLE_KEY=[KEY]

# Stella Maris
SUPABASE_STELLA_MARIS_URL=https://[PROJECT_ID].supabase.co
SUPABASE_STELLA_MARIS_SERVICE_ROLE_KEY=[KEY]

# deepwater
SUPABASE_DEEPWATER_URL=https://[PROJECT_ID].supabase.co
SUPABASE_DEEPWATER_SERVICE_ROLE_KEY=[KEY]
