# =============================================================================
# CAIA-HUB · Environment Template
# =============================================================================
# Copia este archivo a ~/.env.caia-hub y reemplaza cada [PLACEHOLDER]
# con tus credenciales reales:
#
#   cp .env.caia-hub.template ~/.env.caia-hub
#   nano ~/.env.caia-hub
#
# ⚠️  NUNCA subas ~/.env.caia-hub ni este archivo con valores reales al repo.
#     El .gitignore ya excluye los .env (salvo este *.template).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase · CAIA-Hub (proyecto principal) — REQUERIDO
# -----------------------------------------------------------------------------
SUPABASE_CAIA_HUB_URL=https://[project-id].supabase.co
SUPABASE_CAIA_HUB_SERVICE_ROLE_KEY=[service-role-key]

# Opcional: cadena de conexión Postgres directa (para aplicar el schema SQL).
# Si la defines, apply_schema ejecutará el SQL automáticamente.
# SUPABASE_CAIA_HUB_DB_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# NASA · Earthdata / LAADS DAAC
# -----------------------------------------------------------------------------
NASA_EARTHDATA_USERNAME=[nasa-username]
NASA_EARTHDATA_TOKEN=[nasa-earthdata-token]
LAADS_DAAC_TOKEN=[laads-daac-token]

# -----------------------------------------------------------------------------
# Copernicus · CDS / CMEMS
# -----------------------------------------------------------------------------
COPERNICUS_CDS_API_KEY=[copernicus-cds-api-key]
COPERNICUS_CMEMS_USERNAME=[cmems-username]
COPERNICUS_CMEMS_PASSWORD=[cmems-password]

# -----------------------------------------------------------------------------
# USGS · M2M
# -----------------------------------------------------------------------------
USGS_M2M_API_KEY=[usgs-m2m-api-key]

# -----------------------------------------------------------------------------
# ESA · CCI (FTP)
# -----------------------------------------------------------------------------
ESA_CCI_FTP_USER=[esa-cci-ftp-user]
ESA_CCI_FTP_PASS=[esa-cci-ftp-pass]

# -----------------------------------------------------------------------------
# Cross-project bridges (paso 6) — opcionales
# -----------------------------------------------------------------------------
SUPABASE_MOVE_IDWORLD_URL=https://[move-idworld-project-id].supabase.co
SUPABASE_MOVE_IDWORLD_SERVICE_ROLE_KEY=[move-idworld-service-role-key]

SUPABASE_IAGRI_MASTER_URL=https://[iagri-master-project-id].supabase.co
SUPABASE_IAGRI_MASTER_SERVICE_ROLE_KEY=[iagri-master-service-role-key]

SUPABASE_STELLA_MARIS_URL=https://[stella-maris-project-id].supabase.co
SUPABASE_STELLA_MARIS_SERVICE_ROLE_KEY=[stella-maris-service-role-key]

SUPABASE_DEEPWATER_URL=https://[deepwater-project-id].supabase.co
SUPABASE_DEEPWATER_SERVICE_ROLE_KEY=[deepwater-service-role-key]
