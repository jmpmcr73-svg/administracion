# =============================================================================
# DaVinci Hídrico — variables de entorno
# -----------------------------------------------------------------------------
# Copiá este archivo a .env.local (gitignored) y completá los valores.
# En Vercel: Settings -> Environment Variables (Production + Preview).
# NUNCA escribas estos secretos en el código fuente ni los commitees.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://zsmlntktqisiclzaxoky.supabase.co
# Service role: SOLO en el servidor. Jamás exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key: segura para el cliente (cuando se use auth en el navegador).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL pública para el cliente (opcional, igual a SUPABASE_URL).
NEXT_PUBLIC_SUPABASE_URL=https://zsmlntktqisiclzaxoky.supabase.co

# Bucket de Supabase Storage donde se suben las evidencias de cuadrilla.
SUPABASE_EVIDENCIAS_BUCKET=evidencias

# --- Telegram (bot @hidrocr_bot) --------------------------------------------
# Pegar SOLO en Vercel / .env.local. Revocar y regenerar en BotFather (/revoke)
# después del demo: el token anterior se compartió fuera de un canal seguro.
TELEGRAM_BOT_TOKEN=
# Generá un random (p.ej. `openssl rand -hex 32`) y usalo al registrar el webhook.
TELEGRAM_WEBHOOK_SECRET=

# --- WhatsApp vía Twilio (opcional, sandbox) --------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Reportes / correo de supervisión (opcional) ----------------------------
# Si se configura, el cierre de OT dispara un correo a supervisión.
SUPERVISION_EMAIL=
RESEND_API_KEY=

# --- Cron (Vercel Cron -> /api/cron/fuentes) --------------------------------
# Secreto para autenticar el cron (Vercel envía Authorization: Bearer <secret>).
CRON_SECRET=
